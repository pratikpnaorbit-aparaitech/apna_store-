{
  "expo": {
    "name": "Smart Store",
    "slug": "smart-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aparaitech.smartstore",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Smart Store to use your location for nearby stores and delivery."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://apna-store-ol1t.onrender.com/api",
      "eas": {
        "projectId": "cf7f7c86-b60d-4e06-b7db-072b1ec6d7f8"
      }
    }
  }
}
