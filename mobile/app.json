{
  "expo": {
    "name": "Smart Store",
    "slug": "smart-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aparaitech.smartstore",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Smart Store to choose store cover and product images.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Smart Store to use your location for nearby stores and delivery."
        }
      ],
      "expo-font",
      "expo-sharing"
    ],
    "extra": {
      "apiUrl": "https://apna-store-ol1t.onrender.com/api",
      "eas": {
        "projectId": "dc81b945-d098-4e4b-b0f8-e0630ab1ee8b"
      }
    },
    "owner": "yuvi1173"
  }
}
