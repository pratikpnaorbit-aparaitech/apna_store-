# MongoDB connection (example only; keep real credentials in .env or a secret manager)
MONGODB_URI=mongodb+srv://your_user:your_password@your_cluster.mongodb.net/smart_store
# Server Configuration
PORT=5000
NODE_ENV=development
API_RATE_LIMIT_MAX=300
POLLING_RATE_LIMIT_MAX=600

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# One-time Super Admin bootstrap script (backend/create-super-admin.js)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password

# Razorpay (server only; never use the secret in frontend variables)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# Email OTP (Gmail: use smtp.gmail.com, port 465, secure true, and an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="SmartStore <your-email@gmail.com>"

# Twilio (SMS & WhatsApp)
# Twilio credentials - KEEP THESE SECURE!
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE=your_twilio_phone_here
TWILIO_WA_NUMBER=your_twilio_whatsapp_number_here
